{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "development"
    },
    "development-device": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "gradleCommand": ":app:assembleDebug -PreactNativeArchitectures=arm64-v8a"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "production": {
      "autoIncrement": false,
      "channel": "production"
    },
    "staging": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "staging",
      "env": {
        "APP_VARIANT": "staging"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
