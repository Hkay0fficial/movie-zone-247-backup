rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user has an admin role
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'Admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // --- Cafe Menu Content ---
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /cafe_orders/{orderId} {
      // Allow anyone to read, create and update orders (public QR menu)
      // Filtered by tableId in the app logic
      allow read, create, update: if true;
      allow delete: if isAdmin();
    }

    // --- User Profiles & Legacy Movie App Rules ---
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
      
      // Explicitly allow sub-collections like favorites/watchHistory
      match /{allSubcollections=**} {
        allow read, write: if request.auth.uid == userId || isAdmin();
      }
    }

    match /movies/{movieId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}