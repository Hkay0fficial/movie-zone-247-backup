rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if user has an admin role
    function isAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'Admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- Public Content (Everyone can see these) ---
    match /movies/{movieId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /announcements/{annId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /app_layout/{layoutId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- User Profiles & Data ---
    match /users/{userId} {
      // Users can read/write their own profile. Admins can do everything.
      allow read, write: if request.auth.uid == userId || isAdmin();
      
      // Allow searching for users (used in search features)
      allow list: if isAuthenticated() || isAdmin(); 
      
      match /notifications/{notifId} {
        allow read, write: if request.auth.uid == userId || isAdmin();
      }

      match /favorites/{favId} {
        allow read, write: if request.auth.uid == userId || isAdmin();
      }
      
      match /transactions/{txId} {
        allow read: if request.auth.uid == userId || isAdmin();
        allow write: if isAdmin();
      }
    }

    // --- Social & Interaction ---
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // --- Administrative & Billing ---
    match /payments/{paymentId} {
      allow read: if (isAuthenticated() && resource.data.uid == request.auth.uid) || isAdmin();
      allow write: if isAdmin();
    }
    
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    match /user_activity/{activityId} {
      allow read, write: if isAdmin();
    }

    // Default deny for everything else
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
