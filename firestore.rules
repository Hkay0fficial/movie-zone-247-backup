rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to global settings for all users (including guests)
    match /settings/global {
      allow read: if true;
    }
    
    // Allow read access to subscription plans
    match /plans/{planId} {
      allow read: if true;
    }

    // Allow read/write access to device trials for everyone (including guests)
    // This tracks if a specific device has already used its guest trial
    match /device_trials/{deviceId} {
      allow read, write: if true;
    }

    // Main users collection
    match /users/{userId} {
      // Allow users to read and write their own documents
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Sub-collections for users (e.g. favorites, history)
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // App announcements and other public collections
    match /announcements/{announcementId} {
      allow read: if true;
    }
    
    // Public movies/series metadata
    match /movies/{movieId} {
      allow read: if true;
    }
    
    match /series/{seriesId} {
      allow read: if true;
      
      // Episodes subcollection
      match /episodes/{episodeId} {
        allow read: if true;
      }
    }
    
    // Default: allow read but restrict write
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
